# Listen address (host:port). Pi prod typically `0.0.0.0:3003` behind Traefik;
# local dev defaults to 0.0.0.0 too so the LAN can reach the dev box.
SCRIBE_BIND=0.0.0.0:3003

# SQLite database path. Relative paths resolve to the cwd of the running binary.
SCRIBE_DB_PATH=scribe.db

# Loopback URL of the shim Python sidecar.
SCRIBE_SHIM_URL=http://127.0.0.1:3004

# scribe-press (mini ffmpeg worker). Leave unset locally — downloads + jobs
# fail visibly until press is reachable.
# SCRIBE_PRESS_URL=https://mini.lan:3005
# SCRIBE_PRESS_TOKEN=hex-token-from-bw

# scribe-shelf (optional read-only ABS-compat sidecar). Leave unset
# locally if you don't need external clients (Listen This, etc).
# Both required for the settings UI to surface the connection info.
# SCRIBE_SHELF_URL=http://127.0.0.1:3006
# SCRIBE_SHELF_API_KEY=

# Reconvert needs press to be able to fetch local AAXC files via
# /internal/aaxc/{token}; set this to the LAN URL of scribe as seen
# from press. Leave unset locally — reconvert disabled, downloads
# still work.
# SCRIBE_INTERNAL_URL=http://<lan-ip>:3003

# NAS roots — ABS reads from library_dir, never sees original_dir.
# `original_dir` holds the untouched files downloaded from Audible
# (`.aaxc` or `.aax`) for archival + re-convert without re-downloading.
SCRIBE_LIBRARY_DIR=/mnt/audiobooks/library
SCRIBE_ORIGINAL_DIR=/mnt/audiobooks/original

# Polling cadence — mimics human library opens, not a scraper timer.
# Each tick the next sleep is `base · (1 ± jitter)`; outside the active
# hour window the loop sleeps until the next start (+ random 0–30 min
# wake jitter). Default 60 min ± 50% inside 07:00–23:00 local.
SCRIBE_POLL_INTERVAL_MIN=60
SCRIBE_POLL_JITTER_PERCENT=50
SCRIBE_POLL_ACTIVE_HOUR_START=7
SCRIBE_POLL_ACTIVE_HOUR_END=23

# Filename templates. See backend/src/filenaming.rs for the placeholder set.
# SCRIBE_FILENAME_TEMPLATE_M4B={author?}/{series_title?}/[#{series_num} - ]{title}/{title}.m4b
# SCRIBE_FILENAME_TEMPLATE_ORIGINAL={author?}/{series_title?}/{title}-{asin}.aaxc

# Job runner tuning. Concurrency=1 on the Pi (memory-bound); raise on mini.
SCRIBE_JOB_CONCURRENCY=1
SCRIBE_JOB_RETRY_MAX=3
SCRIBE_AUTO_ENQUEUE=0

# Pacing between jobs — applied AFTER each worker finishes a download,
# before pulling the next from the queue. With defaults each gap is
# 30–90 s. Cold-start tip: a 200-book first sync at the floor takes
# ~10 hours of background trickling, but every voucher fetch looks
# like a deliberate user action rather than a scraper burst.
SCRIBE_JOB_INTERJOB_DELAY_S=60
SCRIBE_JOB_INTERJOB_JITTER_PERCENT=50

# audiobookshelf rescan trigger after each completed job. All three must be
# set or scribe silently skips the rescan.
# ABS_URL=http://audiobookshelf.lan:13378
# ABS_TOKEN=abs-api-token
# ABS_LIBRARY_ID=01ab...

# 64-byte hex used to sign session cookies. Generate with `openssl rand -hex 64`.
# Leave unset locally — backend falls back to a non-random key, sessions
# invalidate on every restart in that mode (fine for dev).
# SESSION_KEY=

# Dev cookie shortcut — when `1`, GET /auth/login?username=foo writes a
# session cookie without OIDC. Never enable on a publicly reachable host.
DEV_AUTH=1

# Kanidm OIDC client. Required when DEV_AUTH=0. Created via raspi IaC
# task tasks/kanidm_oidc.py on first deploy; secret lives in BW.
# OIDC_ISSUER=https://kanidm.lan/oauth2/openid/scribe
# OIDC_CLIENT_ID=scribe
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://scribe.lan/auth/callback

# Logging — `info` keeps things quiet, `info,scribe_backend=debug` is the
# default when this is unset.
# RUST_LOG=info,scribe_backend=debug
