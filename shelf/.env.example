# Bind address. Production typically binds 0.0.0.0 so listen-this and
# other ABS-compat clients reach it across the LAN (or through a
# Traefik subdomain with TLS). Dev defaults to loopback.
SHELF_BIND=127.0.0.1:3006

# REQUIRED. Bearer key clients must present in
#   Authorization: Bearer <key>
# Generate with `openssl rand -hex 32`. Rotate by changing the value
# and restarting — no DB row to keep in sync.
SHELF_API_KEY=

# scribe's SQLite file. Opened with SQLITE_OPEN_READ_ONLY so shelf
# can't mutate scribe state even by accident. The default matches
# scribe's own SCRIBE_DB_PATH for shared-host deploys.
SHELF_DB_PATH=./scribe.db

# Canonical M4B output root — same path scribe writes to via
# SCRIBE_LIBRARY_DIR. Shelf serves bytes out of this tree via the
# /api/items/{id}/file/{ino} endpoint.
SHELF_LIBRARY_DIR=/mnt/audiobooks/audible/books

# Display name surfaced on /api/libraries — visible to clients.
# SHELF_LIBRARY_NAME=Audiobooks

# RUST_LOG=info,scribe_shelf=debug
