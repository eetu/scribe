# Passphrase used to encrypt the on-disk Audible auth files. REQUIRED in any
# non-dev deploy — set it to a long random string from BW. The shim refuses
# to start without it unless `SHIM_DEV=1` is also set.
SHIM_PASSPHRASE=

# Where the encrypted per-account JSON files live.
# SHIM_DATA_DIR=./data

# Dev fallback — when `1`, the shim accepts a built-in dev passphrase so
# `uv run shim` works without configuring BW. Never enable in prod.
# SHIM_DEV=1

# Bind/port + reload behaviour of the `uv run shim` launcher.
# Production deploys bypass these (run uvicorn under systemd directly).
# SHIM_HOST=127.0.0.1
# SHIM_PORT=3004
# SHIM_RELOAD=1
# SHIM_LOG=info
