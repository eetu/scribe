# Bind address. Production binds 127.0.0.1; Caddy on the mini fronts the
# external port with bearer auth + TLS. Dev defaults to loopback too.
PRESS_BIND=127.0.0.1:3005

# Bearer token required on every /jobs/* request. `openssl rand -hex 32`.
# REQUIRED — press refuses to start without it.
PRESS_TOKEN=

# Scratch root where per-job tmp dirs land. Default is the system tmp,
# which on macOS is `/var/folders/.../T/scribe-press`. Override to point
# at a fast SSD if the default ends up on a slow disk.
# PRESS_TMP_DIR=/Users/Shared/scribe-press

# Max concurrent ffmpeg jobs. Mini M4 can comfortably do 2–4 at once.
PRESS_MAX_JOBS=2

# Override the ffmpeg path if it's not on PATH (e.g. brew --prefix differs).
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# RUST_LOG=info,scribe_press=debug
